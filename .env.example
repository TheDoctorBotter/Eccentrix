# Supabase Configuration
# These are automatically configured in your environment
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Server-Side Configuration (REQUIRED for file uploads)
# Get these from your Supabase Dashboard -> Project Settings -> API
# WARNING: Keep service role key secret! Never expose in client-side code
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI API Configuration (REQUIRED)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Customize the OpenAI API base URL (for compatible APIs)
# OPENAI_API_BASE=https://api.openai.com/v1

# Optional: Customize the model (default: gpt-4-turbo-preview)
# OPENAI_MODEL=gpt-4-turbo-preview

# Availity Essentials API (Eligibility Verification)
# Register at https://apps.availity.com to get credentials
AVAILITY_CLIENT_ID=
AVAILITY_CLIENT_SECRET=
AVAILITY_API_URL=https://api.availity.com
# DEPRECATED — NPI and Tax ID are now stored per clinic in Supabase (clinics.npi, clinics.tax_id)
# AVAILITY_NPI=
# AVAILITY_TAX_ID=
# Feature flag — set to 'true' only when Availity credentials are active
AVAILITY_ENABLED=false
# Manual fallback portal URL
AVAILITY_PORTAL_URL=https://apps.availity.com

# Stedi integration replaced by Availity — remove these if present:
# STEDI_API_KEY=

# Prisma - Supabase PostgreSQL Connection
# Get these from Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# DATABASE_URL uses the Transaction (pooler) URL (port 6543) for runtime queries
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:YOUR-PASSWORD@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL uses the Session (direct) URL (port 5432) for migrations
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:YOUR-PASSWORD@aws-0-[REGION].pooler.supabase.com:5432/postgres"
